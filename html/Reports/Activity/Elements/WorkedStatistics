<%args>
$query => ""
$start => "2005/01/01"
$end   => "2006/01/01"
$actor => ""
</%args>
<%init>
my $startDate = RT::Date->new($session{'CurrentUser'});
$startDate->Set(Format => 'unknown', Value => $start);
my $endDate   = RT::Date->new($session{'CurrentUser'});
$endDate->Set(Format => 'unknown', Value => $end);
my(%queue, %user);
my $Queues = RT::Queues->new($session{'CurrentUser'});
$Queues->UnLimit();
while (my $queue = $Queues->Next) {
    my $tix = RT::Tickets->new($session{'CurrentUser'});
    $tix->FromSQL("Queue = '@{[$queue->Name]}' AND (Status = 'open' OR Status = 'new')");
    $queue{$queue->Id}{name}       = $queue->Name;
    $queue{$queue->Id}{total_open} = $tix->Count();
}
my $actor_query = '';
$actor_query = "(Owner = '$actor')" if $actor;
my $tix = RT::Tickets->new($session{'CurrentUser'});
$tix->FromSQL(join " AND ", map {"($_)"} grep {/\S/} ($query, $actor_query, "Updated >= '$start' AND Updated <= '$end'"));
while (my $ticket = $tix->Next) {
    my $created  = $ticket->CreatedObj;
    my %bins;
    $bins{created} = 1 if $created->Unix > $startDate->Unix and $created->Unix < $endDate->Unix;
    my $opened = $created;
    my $txns = $ticket->Transactions;
    while (my $txn = $txns->Next) {
        last if $txn->CreatedObj->Unix > $endDate->Unix;
        if (not $opened and $txn->Type eq "Status" and $txn->NewValue =~ /new|open/) {
            $opened = $txn->CreatedObj;
        } elsif ($opened and $txn->Type eq "Status" and $txn->NewValue eq "resolved") {
            if ($txn->CreatedObj->Unix >= $startDate->Unix) {
                $bins{resolved} = 1;
                my $time = $txn->CreatedObj->Diff($opened);
                $time = ($time < 24*60*60 ? "24" : ($time < 48*60*60 ? "48" : "more"));
                $queue{$ticket->Queue}{$_}{$time}++    for keys %bins;
                $queue{$ticket->Queue}{$_}{resolves}++ for keys %bins;
                $user{$txn->CreatorObj->Name}{$ticket->Queue}{$time}++;
                $user{$txn->CreatorObj->Name}{$ticket->Queue}{resolves}++;
                $user{$txn->CreatorObj->Name}{$ticket->Queue}{tickets}{$ticket->Id}++;
            }
            undef $opened;
        }
        if ($txn->TimeTaken and $txn->CreatedObj->Unix >= $startDate->Unix) {
            $queue{$ticket->Queue}{time} += $txn->TimeTaken;
            $user{$txn->CreatorObj->Name}{$ticket->Queue}{time} += $txn->TimeTaken;
            $user{$txn->CreatorObj->Name}{$ticket->Queue}{tickets}{$ticket->Id}++;
        }
    }
    for my $bin (keys %bins) {
        $queue{$ticket->Queue}{$bin}{tickets}++;
        $queue{$ticket->Queue}{$bin}{open}++ if $ticket->Status =~ /new|open/;
    }
}
my %plot;
for (keys %queue) {
    $plot{$queue{$_}{name}} = {
        "< 24h"  => $queue{$_}{resolved}{24},
        "24-48h" => $queue{$_}{resolved}{48},
        "> 48h"  => $queue{$_}{resolved}{more},
    };
}
</%init>
<div class="ar-card">
  <div class="ar-card-header">Queue Resolution Statistics</div>
  <div class="ar-card-body">
    <& MiniPlot, data => \%plot, minor => ["< 24h","24-48h","> 48h"] &>
    <div class="ar-table-wrap">
      <table class="ar-table">
        <thead>
          <tr>
            <th rowspan="2">Queue</th>
            <th class="ar-group-header" colspan="6">Created in date range</th>
            <th class="ar-group-header" colspan="6">Resolved in date range</th>
            <th rowspan="2" class="ar-num">Still&nbsp;Open</th>
          </tr>
          <tr>
            <th class="ar-num">Total</th><th class="ar-num">Resolved</th>
            <th class="ar-num">&lt;&nbsp;24h</th><th class="ar-num">24-48h</th>
            <th class="ar-num">&gt;&nbsp;48h</th><th class="ar-num">Open</th>
            <th class="ar-num">Total</th><th class="ar-num">Resolved</th>
            <th class="ar-num">&lt;&nbsp;24h</th><th class="ar-num">24-48h</th>
            <th class="ar-num">&gt;&nbsp;48h</th><th class="ar-num">Open</th>
          </tr>
        </thead>
        <tbody>
% my @totals;
% for my $queue (sort {lc $queue{$a}{name} cmp lc $queue{$b}{name}} keys %queue) {
%   my @row; my $i = 0;
          <tr>
            <th class="ar-th-label"><% $queue{$queue}{name} |h %></th>
%   for my $bin (qw/created resolved/) {
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{tickets}  || 0 %></td>
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{resolves} || 0 %></td>
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{24}       || 0 %></td>
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{48}       || 0 %></td>
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{more}     || 0 %></td>
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{$bin}{open}     || 0 %></td>
%   }
            <td class="ar-num"><% $row[$i++] = $queue{$queue}{total_open} %></td>
          </tr>
%   $totals[$_] += $row[$_] for 0..$#row;
% }
        </tbody>
        <tfoot>
          <tr>
            <th class="ar-th-label">Total</th>
% for (@totals) {
            <td class="ar-num"><% $_ %></td>
% }
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>

<div class="ar-card mt-3">
  <div class="ar-card-header">User Performance by Queue</div>
  <div class="ar-card-body">
    <div class="ar-table-wrap">
      <table class="ar-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Queue</th>
            <th class="ar-num">&lt;&nbsp;24h</th>
            <th class="ar-num">24-48h</th>
            <th class="ar-num">&gt;&nbsp;48h</th>
            <th class="ar-num">Time&nbsp;worked&nbsp;(h)</th>
            <th class="ar-num">Avg&nbsp;min/ticket</th>
            <th class="ar-num">Resolutions/h</th>
          </tr>
        </thead>
        <tbody>
% for my $user (sort keys %user) {
%   for my $queue (sort {lc $queue{$a}{name} cmp lc $queue{$b}{name}} keys %{$user{$user}}) {
          <tr>
            <th class="ar-th-label"><% $user |h %></th>
            <th class="ar-th-label" style="font-weight:400"><% $queue{$queue}{name} |h %></th>
            <td class="ar-num"><% $user{$user}{$queue}{24}   || 0 %></td>
            <td class="ar-num"><% $user{$user}{$queue}{48}   || 0 %></td>
            <td class="ar-num"><% $user{$user}{$queue}{more} || 0 %></td>
            <td class="ar-num"><% sprintf("%.2f", ($user{$user}{$queue}{time} || 0) / 60) %></td>
            <td class="ar-num"><% sprintf("%.2f", ($user{$user}{$queue}{time} || 0) / (scalar keys %{$user{$user}{$queue}{tickets}} || 1)) %></td>
            <td class="ar-num"><% $user{$user}{$queue}{time} ? sprintf("%.2f", ($user{$user}{$queue}{resolves} || 0) / ($user{$user}{$queue}{time} / 60)) : "-" %></td>
          </tr>
%   }
% }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="ar-card mt-3">
  <div class="ar-card-header">Still open - created in date range</div>
  <div class="ar-card-body" style="padding:0.75rem">
    <& /Elements/CollectionList,
        Query   => qq{ ( Created >= '$start'  AND Created <= '$end' ) AND ( Status = 'new'  OR Status = 'open' ) },
        OrderBy => 'Created',
        Order   => 'ASC',
        Format  => q{'   <b><a href="__WebPath__/Ticket/Display.html?id=__id__">__id__</a></b>/TITLE:#','<a href="__WebPath__/Ticket/Display.html?id=__id__">__Subject__</a>/TITLE:Subject','__QueueName__','__Created__'},
        Rows    => 0,
        BaseURL => $RT::WebPath."/Search/Results.html?",
        AllowSorting => 1,
        Class => 'RT::Tickets',
    &>
  </div>
</div>
